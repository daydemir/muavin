#!/bin/sh
set -eu

SAFE_PATH="${MUAVIN_ORIGINAL_PATH:-/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin}"
REAL_TMUX="$(PATH="$SAFE_PATH" /usr/bin/which tmux 2>/dev/null || true)"

if [ -z "$REAL_TMUX" ] || [ "$REAL_TMUX" = "$0" ]; then
  echo "muavin guard: real tmux binary not found" >&2
  exit 127
fi

usage() {
  echo "Usage: tmux-send <session-or-pane> <prompt>" >&2
  exit 64
}

[ $# -ge 2 ] || usage

target="$1"
shift
prompt="$*"

[ -n "$prompt" ] || usage

resolve_pane() {
  case "$1" in
    %*)
      pane_id="$1"
      session_name="$("$REAL_TMUX" display-message -p -t "$pane_id" "#{session_name}" 2>/dev/null || true)"
      [ -n "$session_name" ] || return 1
      printf "%s\t%s\n" "$session_name" "$pane_id"
      ;;
    *)
      session_name="$1"
      pane_id="$("$REAL_TMUX" display-message -p -t "$session_name" "#{pane_id}" 2>/dev/null || true)"
      [ -n "$pane_id" ] || return 1
      printf "%s\t%s\n" "$session_name" "$pane_id"
      ;;
  esac
}

resolved="$(resolve_pane "$target" || true)"
[ -n "$resolved" ] || {
  echo "tmux-send: target not found: $target" >&2
  exit 1
}

session_name="$(printf "%s" "$resolved" | cut -f1)"
pane_id="$(printf "%s" "$resolved" | cut -f2)"

"$REAL_TMUX" send-keys -t "$pane_id" -l "$prompt"
"$REAL_TMUX" send-keys -t "$pane_id" Enter

printf "Sent prompt to %s (%s).\n" "$session_name" "$pane_id"
